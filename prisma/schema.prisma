generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LineUser {
  id           String     @id @default(cuid())
  lineUserId   String     @unique
  displayName  String?
  createdAt    DateTime   @default(now())
  state        String?
  userId       String?
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  credits   Int
  stripeId  String?
  createdAt DateTime @default(now())
}

model AdMetrics {
  id          String   @id @default(cuid())
  date        DateTime
  campaign    String
  impressions Int      @default(0)
  clicks      Int      @default(0)
  spend       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, campaign])
}

model ListJob {
  id               String         @id @default(cuid())
  userId           String
  keyword          String
  industry         String?
  location         String?
  targetCount      Int            @default(100)
  status           String         @default("pending")
  progress         Int            @default(0)
  totalFound       Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  completedAt      DateTime?
  confirmedAt      DateTime?
  originalMessage  String?
  reservedCredits  Int        @default(0)
  source           String     @default("line")
  retryCount       Int        @default(0)
  searchQueries    String?
  industryKeywords String[]
  urls             CollectedUrl[]
  geminiUsageLogs  GeminiUsageLog[]
}

model CollectedUrl {
  id                  String   @id @default(cuid())
  jobId               String
  url                 String
  domain              String
  companyName         String?
  industry            String?
  location            String?
  employeeCount       String?
  capitalAmount       String?
  phoneNumber         String?
  representativeName  String?
  establishedYear     Int?
  businessDescription String?
  email               String?
  snsLinks            String?              // JSON: {"x":"url","instagram":"url","facebook":"url","youtube":"url"}
  hasRecruitPage      Boolean  @default(false)
  siteUpdatedAt       String?              // サイト最終更新日（テキスト）
  searchTags          String[]             // 検索タグ（5-10個）
  industryMajor       String?              // 業種大分類
  industryMinor       String?              // 業種小分類
  hasForm             Boolean  @default(false)
  formUrl             String?
  companyVerified     Boolean  @default(false)
  excluded            Boolean  @default(false)
  status              String   @default("collected")
  createdAt           DateTime @default(now())
  job                 ListJob  @relation(fields: [jobId], references: [id])
}

model SearchLog {
  id          String   @id @default(cuid())
  userId      String?
  lineUserId  String?
  keyword     String?
  industry    String?
  location    String?
  targetCount Int
  jobId       String?
  createdAt   DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model GeminiUsageLog {
  id               String   @id @default(cuid())
  jobId            String?
  source           String
  inputTokens      Int
  outputTokens     Int
  estimatedCostJpy Float
  createdAt        DateTime @default(now())

  job              ListJob? @relation(fields: [jobId], references: [id])
}

model LineLinkCode {
  id        String    @id @default(cuid())
  userId    String
  code      String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}
