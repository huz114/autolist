generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LineUser {
  id           String     @id @default(cuid())
  lineUserId   String     @unique
  displayName  String?
  plan         String     @default("free")
  monthlyCount Int        @default(0)
  createdAt    DateTime   @default(now())
  credits      Int        @default(100)
  state        String?
  userId       String?
  jobs         ListJob[]
  purchases    Purchase[]
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  credits   Int
  stripeId  String?
  createdAt DateTime @default(now())
  user      LineUser @relation(fields: [userId], references: [id])
}

model AdMetrics {
  id          String   @id @default(cuid())
  date        DateTime
  campaign    String
  impressions Int      @default(0)
  clicks      Int      @default(0)
  spend       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, campaign])
}

model ListJob {
  id               String         @id @default(cuid())
  userId           String
  keyword          String
  industry         String?
  location         String?
  targetCount      Int            @default(100)
  status           String         @default("pending")
  progress         Int            @default(0)
  totalFound       Int            @default(0)
  createdAt        DateTime       @default(now())
  completedAt      DateTime?
  originalMessage  String?
  industryKeywords String[]
  urls             CollectedUrl[]
  user             LineUser       @relation(fields: [userId], references: [id])
}

model CollectedUrl {
  id                 String   @id @default(cuid())
  jobId              String
  url                String
  domain             String
  companyName        String?
  industry           String?
  location           String?
  employeeCount      String?
  capitalAmount      String?
  phoneNumber        String?
  representativeName String?
  hasForm            Boolean  @default(false)
  formUrl            String?
  companyVerified    Boolean  @default(false)
  status             String   @default("collected")
  createdAt          DateTime @default(now())
  job                ListJob  @relation(fields: [jobId], references: [id])
}

model SearchLog {
  id          String   @id @default(cuid())
  userId      String?
  lineUserId  String?
  keyword     String?
  industry    String?
  location    String?
  targetCount Int
  jobId       String?
  createdAt   DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}
