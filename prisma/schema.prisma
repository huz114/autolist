generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LineUser {
  id           String    @id @default(cuid())
  lineUserId   String    @unique
  displayName  String?
  plan         String    @default("free")
  monthlyCount Int       @default(0)
  credits      Int       @default(100)
  state        String?
  createdAt    DateTime  @default(now())
  userId       String?   // シリョログのUser.idを参照（外部キー制約なし）
  jobs         ListJob[]
}

model ListJob {
  id          String         @id @default(cuid())
  userId      String
  keyword     String
  industry    String?
  location    String?
  targetCount Int            @default(100)
  status      String         @default("pending")
  progress    Int            @default(0)
  totalFound  Int            @default(0)
  createdAt   DateTime       @default(now())
  completedAt DateTime?
  urls        CollectedUrl[]
  user        LineUser       @relation(fields: [userId], references: [id])
}

model CollectedUrl {
  id                 String   @id @default(cuid())
  jobId              String
  url                String
  domain             String
  companyName        String?
  industry           String?
  location           String?
  employeeCount      String?
  capitalAmount      String?
  phoneNumber        String?
  representativeName String?
  hasForm            Boolean  @default(false)
  formUrl            String?
  status             String   @default("collected")
  createdAt          DateTime @default(now())
  job                ListJob  @relation(fields: [jobId], references: [id])
}

model SearchLog {
  id          String   @id @default(cuid())
  userId      String?
  lineUserId  String?
  keyword     String?
  industry    String?
  location    String?
  targetCount Int
  jobId       String?
  createdAt   DateTime @default(now())
}
